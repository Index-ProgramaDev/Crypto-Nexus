# ==========================================
# CryptoHub Backend - Environment Variables
# ==========================================
# Renomeie este arquivo para .env e preencha os valores

# Server Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database - PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/cryptohub?schema=public"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Security
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Optional: Cloud Storage (AWS S3, Cloudflare R2)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=

# Optional: Email Service (SendGrid, Resend)
# EMAIL_FROM=noreply@cryptohub.com
# SENDGRID_API_KEY=
# RESEND_API_KEY=

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Admin Configuration
DEFAULT_ADMIN_EMAIL=admin@cryptohub.com
DEFAULT_ADMIN_PASSWORD=admin123
